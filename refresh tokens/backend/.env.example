MONGO_URI=mongodb://localhost:27017/refresh_tokens_db
CONTAINER_NAME=refresh_tokens_mongo
PORT=4000
FRONTEND_URL=http://localhost:5173

# Use strong random secrets in production: openssl rand -hex 64
ACCESS_TOKEN_SECRET=change_me_access_secret
ACCESS_TOKEN_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=change_me_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=7d

NODE_ENV=development
